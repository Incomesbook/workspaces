# OS / editors
.DS_Store
Thumbs.db
*.lnk

# Node / Python typical
node_modules/
dist/
build/
__pycache__/
*.pyc

# VS Code
.vscode/*
!.vscode/settings.json
!.vscode/extensions.json
!.vscode/tasks.json

# Big caches / histories / collected FS / chat logs (important for your case)
**/.tmp/
**/_LIVE/
**/_COLLECTED_FS/
**/workspaceStorage/
**/Cache/
**/Code Cache/
**/GPUCache/
**/IndexedDB/
**/Local Storage/
**/Session Storage/
**/Service Worker/
**/Sentry/
**/logs/
**/*.log
**/*.ldb
**/*.sqlite
**/*.sqlite-journal
**/*.jsonl

# Secrets and local credentials must stay out of GitHub
**/.env
**/.env.*
**/api_keys.txt
**/*secret*
**/*secrets*
**/*credential*
**/*credentials*
**/*token*
**/*password*
**/S09_Shared_Private/

# Bulky generated media / archives
**/*.mp4
**/*.mkv
**/*.mov
**/*.avi
**/*.webm
**/*.zip
**/*.7z
**/*.rar
